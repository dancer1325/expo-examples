{
  "main": "expo-router/entry",
  "scheme": "with-graphql",
  "dependencies": {
    "expo": "^57.0.1",
    "expo-constants": "~57.0.2",
    "expo-linking": "~57.0.1",
    "expo-router": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "gql.tada": "^1.8.12",
    "graphql-yoga": "^5.15.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.0",
    "urql": "^4.2.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.14",
    "typescript": "~6.0.3"
  },
  "name": "with-graphql",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "sync:schema": "gql-tada generate schema http://localhost:8081/api/graphql --output ./src/schema.graphql",
    "sync:types": "gql-tada generate output"
  }
